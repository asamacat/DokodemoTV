<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Group centered, slightly scaled to fit well in adaptive icon bounds -->
    <group android:translateX="24" android:translateY="24">
        <!-- Modern, minimalist TV/Monitor screen (The "Demo" part) -->
        <path
            android:fillColor="#E6F2F5"
            android:pathData="M 6,8
                              C 2,8 0,10 0,14
                              L 0,40
                              C 0,44 2,46 6,46
                              L 54,46
                              C 58,46 60,44 60,40
                              L 60,14
                              C 60,10 58,8 54,8
                              Z" />

        <!-- Screen inner area (Inner TV) -->
        <path
            android:fillColor="#151E28"
            android:pathData="M 6,12 L 54,12 L 54,42 L 6,42 Z" />

        <!-- "Play" icon / Demo indicator inside the screen -->
        <path
            android:fillColor="#00E5FF"
            android:pathData="M 26,20 L 38,27 L 26,34 Z" />

        <!-- TV Stand / Docking Base (The "Dock" part) -->
        <path
            android:fillColor="#90A4AE"
            android:pathData="M 24,46 L 36,46 L 40,54 L 20,54 Z" />

        <!-- Base line of the dock -->
        <path
            android:fillColor="#CFD8DC"
            android:pathData="M 12,54 L 48,54 C 50,54 50,56 48,56 L 12,56 C 10,56 10,54 12,54 Z" />

        <!-- Minimal Antenna / Signal lines (A nod to TV broadcast/Japanese minimalism) -->
