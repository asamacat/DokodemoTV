            android:strokeColor="#90A4AE"
            android:strokeWidth="2"
            android:strokeLineCap="round"
            android:pathData="M 20,8 L 14,2" />
        <path
            android:strokeColor="#90A4AE"
            android:strokeWidth="2"
            android:strokeLineCap="round"
            android:pathData="M 40,8 L 46,2" />
    </group>
</vector>
